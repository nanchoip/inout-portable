<Window x:Class="InoutPortable.App.CompanySelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar empresa de a3ERP" Height="500" Width="660"
        WindowStartupLocation="CenterOwner" Background="White">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Empresas registradas en la base de datos de sistema de a3ERP. Al elegir una se usará su base de datos automáticamente." />

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Usuario a3ERP (opcional):" VerticalAlignment="Center"
                       Margin="0,0,8,10" Style="{StaticResource Muted}" />
            <TextBox Grid.Column="1" x:Name="UserBox" VerticalAlignment="Center"
                     ToolTip="Filtra las empresas por los permisos de ese usuario de a3ERP. Vacío = todas." />
            <Button Grid.Column="2" Content="Actualizar" Style="{StaticResource Secondary}"
                    Margin="10,0,0,10" Click="Refresh_Click" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Filtrar:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Muted}" />
            <TextBox Grid.Column="1" x:Name="SearchBox" VerticalAlignment="Center" Height="28" Margin="0"
                     TextChanged="SearchBox_TextChanged" ToolTip="Escribe para filtrar por nombre o base de datos." />
        </Grid>

        <DataGrid x:Name="CompaniesGrid" Grid.Row="3" MouseDoubleClick="Companies_DoubleClick" RowHeight="34">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="46">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding LogoImage}" Height="26" MaxWidth="40" Margin="2"
                                   Stretch="Uniform" HorizontalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Empresa" Binding="{Binding Description}" Width="*" />
                <DataGridTextColumn Header="Base de datos" Binding="{Binding DatabaseName}" Width="160" />
                <DataGridTextColumn Header="Servidor" Binding="{Binding ServerName}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Style="{StaticResource Muted}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Style="{StaticResource Secondary}" Click="Cancel_Click" />
                <Button x:Name="UseBtn" Content="Usar empresa" Margin="10,0,0,0" Click="Use_Click" IsEnabled="False" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
