<Window x:Class="InoutPortable.App.CredentialsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Credenciales de SQL Server" Height="250" Width="420"
        WindowStartupLocation="CenterOwner" Background="White" ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="Introduce las credenciales para conectar al servidor de a3ERP." />

        <CheckBox x:Name="IntegratedBox" Content="Usar autenticación de Windows"
                  Margin="0,0,0,10" Checked="Integrated_Changed" Unchecked="Integrated_Changed" />

        <TextBlock Text="Usuario" Style="{StaticResource FieldLabel}" />
        <TextBox x:Name="UserBox" />

        <TextBlock Text="Contraseña" Style="{StaticResource FieldLabel}" />
        <PasswordBox x:Name="PassBox" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancelar" Style="{StaticResource Secondary}" Click="Cancel_Click" />
            <Button Content="Aceptar" Margin="10,0,0,0" Click="Ok_Click" IsDefault="True" />
        </StackPanel>
    </StackPanel>
</Window>
