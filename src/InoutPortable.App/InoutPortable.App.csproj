<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\InoutPortable.Core\InoutPortable.Core.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>

    <!-- Friendly identity -->
    <AssemblyName>InoutPortable</AssemblyName>
    <AssemblyTitle>inout Portable</AssemblyTitle>
    <Product>inout Portable</Product>
    <Company>inout Portable</Company>
    <Version>1.0.0</Version>
    <FileVersion>1.0.0.0</FileVersion>
    <Description>Importador de Excel a Microsoft SQL Server (estilo inout de a3ERP)</Description>
    <SatelliteResourceLanguages>en;es</SatelliteResourceLanguages>

    <!-- Publish-time options (single-file, self-contained) live in build/publish.ps1 so that
         normal `dotnet build` / `dotnet test` stay framework-dependent and fast. -->
  </PropertyGroup>

</Project>
