<Window x:Class="InoutPortable.App.InstanceScanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar instancias de SQL Server" Height="460" Width="720"
        WindowStartupLocation="CenterOwner" Background="White">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Busca servidores SQL Server en la red (UDP 1434). Las instancias de a3ERP se llaman 'A3ERP' y aparecen primero. Si el servidor está en otra subred, escribe su IP y pulsa Buscar." />

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="HostBox" Grid.Column="0" VerticalAlignment="Center"
                     ToolTip="IP o nombre de host concreto (opcional)" />
            <Button x:Name="ScanBtn" Grid.Column="1" Content="Buscar" Margin="10,0,0,10" Click="Scan_Click" />
        </Grid>

        <DataGrid x:Name="ResultsGrid" Grid.Row="2" MouseDoubleClick="Results_DoubleClick">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="a3ERP" Binding="{Binding IsA3Erp}" Width="60" />
                <DataGridTextColumn Header="Servidor" Binding="{Binding Server}" Width="*" />
                <DataGridTextColumn Header="Instancia" Binding="{Binding Instance}" Width="140" />
                <DataGridTextColumn Header="Puerto" Binding="{Binding TcpPort}" Width="80" />
                <DataGridTextColumn Header="Versión" Binding="{Binding Version}" Width="130" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Style="{StaticResource Muted}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Style="{StaticResource Secondary}" Click="Cancel_Click" />
                <Button x:Name="UseBtn" Content="Usar seleccionada" Margin="10,0,0,0" Click="Use_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
