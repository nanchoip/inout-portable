<Window x:Class="InoutPortable.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="inout Portable — Importador a SQL Server"
        Height="740" Width="1100" MinHeight="580" MinWidth="920"
        WindowStartupLocation="CenterScreen" Background="White">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#0F172A" Padding="18,12">
            <Grid>
                <StackPanel>
                    <TextBlock Text="inout Portable" Foreground="White" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="Importación de Excel a Microsoft SQL Server (cada hoja = una tabla)"
                               Foreground="#94A3B8" FontSize="12" />
                </StackPanel>
                <TextBlock x:Name="ConnStatus" Text="● Sin conexión configurada"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="#FCA5A5" FontSize="12" FontWeight="SemiBold" />
            </Grid>
        </Border>

        <TabControl x:Name="Tabs" BorderThickness="0" Padding="0" Background="White">
            <!-- ============ TAB 1: CONEXIÓN ============ -->
            <TabItem Header="1 · Conexión">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24" MaxWidth="560" HorizontalAlignment="Left">
                        <TextBlock Text="Conexión a SQL Server" Style="{StaticResource H1}" />
                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14"
                                   Text="Introduce los datos del servidor destino. La contraseña se guarda cifrada (DPAPI) en el equipo." />

                        <Grid>
                            <TextBlock Text="Servidor / host" Style="{StaticResource FieldLabel}" />
                            <Button x:Name="ScanBtn" Content="Buscar instancias A3ERP…" Style="{StaticResource Secondary}"
                                    HorizontalAlignment="Right" Padding="10,3" FontSize="11" Margin="0,-4,0,0"
                                    Click="ScanInstances_Click" />
                        </Grid>
                        <TextBox x:Name="HostBox" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Instancia (opcional)" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="InstanceBox" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Puerto (opcional)" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="PortBox" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Base de datos" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="DbBox" />

                        <CheckBox x:Name="IntegratedBox" Content="Usar autenticación de Windows"
                                  Margin="0,4,0,10" Checked="Integrated_Changed" Unchecked="Integrated_Changed" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Usuario" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="UserBox" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Contraseña" Style="{StaticResource FieldLabel}" />
                                <PasswordBox x:Name="PassBox" />
                            </StackPanel>
                        </Grid>

                        <CheckBox x:Name="EncryptBox" Content="Cifrar la conexión (Encrypt)" IsChecked="True" Margin="0,4,0,6" />
                        <CheckBox x:Name="TrustBox" Content="Confiar en el certificado del servidor (TrustServerCertificate)" IsChecked="True" Margin="0,0,0,14" />

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="TestBtn" Content="Probar conexión" Style="{StaticResource Secondary}" Click="TestConnection_Click" />
                            <Button x:Name="SaveBtn" Content="Guardar" Margin="10,0,0,0" Click="SaveConnection_Click" />
                        </StackPanel>

                        <TextBlock x:Name="ConnResult" TextWrapping="Wrap" Margin="0,14,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ TAB 2: IMPORTAR ============ -->
            <TabItem Header="2 · Importar">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="3*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- File selection -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FilePathBox" Grid.Column="0" IsReadOnly="True" VerticalAlignment="Center"
                                 Text="" Foreground="#334155" />
                        <Button x:Name="BrowseBtn" Grid.Column="1" Content="Examinar…" Style="{StaticResource Secondary}"
                                Margin="10,0,0,10" Click="Browse_Click" />
                        <Button x:Name="AnalyzeBtn" Grid.Column="2" Content="Analizar" Margin="10,0,0,10" Click="Analyze_Click" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <TextBlock Text="Resumen por tabla" Style="{StaticResource H2}" VerticalAlignment="Center" />
                        <Button x:Name="KeyBtn" Content="Definir clave de la hoja…" Style="{StaticResource Secondary}"
                                HorizontalAlignment="Right" Padding="10,4" FontSize="11" Click="DefineKey_Click" />
                    </Grid>

                    <!-- Summary grid -->
                    <DataGrid x:Name="SummaryGrid" Grid.Row="2" IsReadOnly="False"
                              SelectionChanged="SummaryGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Importar" Binding="{Binding Include, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                            <DataGridTextColumn Header="Hoja" Binding="{Binding Sheet}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Tabla destino" Binding="{Binding Table}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Cabecera fila" Binding="{Binding HeaderRow}" Width="90" IsReadOnly="True" />
                            <DataGridTextColumn Header="Insertar" Binding="{Binding Insert}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="Actualizar" Binding="{Binding Update}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="Errores" Binding="{Binding Errors}" Width="70" IsReadOnly="True" />
                            <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="170" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Details: issues + preview -->
                    <TabControl Grid.Row="3" Margin="0,12,0,0" BorderBrush="{StaticResource LineBrush}">
                        <TabItem Header="Problemas detectados">
                            <DataGrid x:Name="IssuesGrid">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ubicación" Binding="{Binding Location}" Width="260" />
                                    <DataGridTextColumn Header="Gravedad" Binding="{Binding Severity}" Width="90" />
                                    <DataGridTextColumn Header="Motivo" Binding="{Binding Message}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Vista previa">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,6,0,8">
                                    <TextBlock Text="Hoja:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Muted}" />
                                    <ComboBox x:Name="PreviewSheetCombo" Width="220" Height="28"
                                              SelectionChanged="PreviewSheetCombo_SelectionChanged" />
                                    <TextBlock x:Name="PreviewNote" VerticalAlignment="Center" Margin="12,0,0,0" Style="{StaticResource Muted}" />
                                </StackPanel>
                                <DataGrid x:Name="PreviewGrid" Grid.Row="1" AutoGenerateColumns="True" />
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <!-- Bottom bar -->
                    <Grid Grid.Row="4" Margin="0,14,0,0">
                        <TextBlock x:Name="ImportStatus" VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="ConfirmBtn" Content="Confirmar e importar" HorizontalAlignment="Right"
                                IsEnabled="False" Click="Confirm_Click" Background="{StaticResource OkBrush}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB 3: HISTORIAL ============ -->
            <TabItem Header="3 · Historial">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Historial de importaciones" Style="{StaticResource H1}" VerticalAlignment="Center" />
                        <Button Content="Refrescar" Style="{StaticResource Secondary}" Margin="16,0,0,0" Click="RefreshHistory_Click" />
                    </StackPanel>
                    <DataGrid x:Name="HistoryGrid" Grid.Row="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha/hora" Binding="{Binding When}" Width="150" />
                            <DataGridTextColumn Header="Archivo" Binding="{Binding FileName}" Width="*" />
                            <DataGridTextColumn Header="Insertadas" Binding="{Binding Inserted}" Width="90" />
                            <DataGridTextColumn Header="Actualizadas" Binding="{Binding Updated}" Width="100" />
                            <DataGridTextColumn Header="Omitidas" Binding="{Binding Skipped}" Width="90" />
                            <DataGridTextColumn Header="Resultado" Binding="{Binding Result}" Width="120" />
                            <DataGridTextColumn Header="Detalle" Binding="{Binding Message}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
