<Window x:Class="InoutPortable.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="inout Portable — Importador/Exportador SQL Server"
        Height="760" Width="1120" MinHeight="600" MinWidth="940"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="13"
        Background="{StaticResource CanvasBrush}">
    <DockPanel>
        <!-- ===================== Header ===================== -->
        <Border DockPanel.Dock="Top" Padding="22,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0F172A" Offset="0" />
                    <GradientStop Color="#1E293B" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Width="38" Height="38" CornerRadius="10" Background="#2563EB" VerticalAlignment="Center">
                        <TextBlock Text="⇄" Foreground="White" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="inout Portable" Foreground="White" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="Importar / exportar Excel ⇄ Microsoft SQL Server, estilo a3ERP"
                                   Foreground="#94A3B8" FontSize="12" />
                    </StackPanel>
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" CornerRadius="20"
                        Background="#172033" Padding="12,6" BorderBrush="#334155" BorderThickness="1">
                    <TextBlock x:Name="ConnStatus" Text="● Sin conexión configurada"
                               Foreground="#FCA5A5" FontSize="12" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <TabControl x:Name="Tabs">
            <!-- ============ TAB 1: CONEXIÓN ============ -->
            <TabItem Header="1 · Conexión">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel Margin="24" MaxWidth="760" HorizontalAlignment="Left">

                        <!-- Quick connect -->
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Conexión rápida a a3ERP" Style="{StaticResource H1}" />
                                <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14"
                                           Text="Detecta el servidor y elige la empresa en un clic. Las credenciales SQL se piden solo la primera vez (luego se guardan cifradas)." />
                                <WrapPanel>
                                    <Button x:Name="ScanBtn" Style="{StaticResource Secondary}" Content="🔍  Buscar instancias A3ERP"
                                            Padding="14,9" Margin="0,0,10,10" Click="ScanInstances_Click" />
                                    <Button x:Name="IniBtn" Style="{StaticResource Secondary}" Content="📁  Cargar servidor (Sistema.ini)"
                                            Padding="14,9" Margin="0,0,10,10" Click="LoadFromIni_Click" />
                                    <Button x:Name="NativeCompanyBtn" Style="{StaticResource Secondary}" Content="🏢  Selector nativo de a3ERP"
                                            Padding="14,9" Margin="0,0,10,10" Click="NativeSelector_Click" />
                                    <Button x:Name="CompanyBtn" Style="{StaticResource Secondary}" Content="🏬  Elegir empresa a3ERP"
                                            Padding="14,9" Margin="0,0,10,10" Click="ChooseCompany_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Manual connection -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Datos de conexión" Style="{StaticResource H1}" />
                                <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14"
                                           Text="O introdúcelos manualmente. La contraseña se guarda cifrada (DPAPI) en este equipo." />

                                <TextBlock Text="Servidor / host" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="HostBox" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Instancia (opcional)" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="InstanceBox" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Puerto (opcional)" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="PortBox" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Base de datos" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="DbBox" />

                                <CheckBox x:Name="IntegratedBox" Content="Usar autenticación de Windows"
                                          Margin="0,4,0,12" Checked="Integrated_Changed" Unchecked="Integrated_Changed" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Usuario" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="UserBox" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Contraseña" Style="{StaticResource FieldLabel}" />
                                        <PasswordBox x:Name="PassBox" />
                                    </StackPanel>
                                </Grid>

                                <CheckBox x:Name="EncryptBox" Content="Cifrar la conexión (Encrypt)" IsChecked="True" Margin="0,4,0,6" />
                                <CheckBox x:Name="TrustBox" Content="Confiar en el certificado del servidor (TrustServerCertificate)" IsChecked="True" Margin="0,0,0,16" />

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="TestBtn" Content="Probar conexión" Style="{StaticResource Secondary}" Padding="14,9" Click="TestConnection_Click" />
                                    <Button x:Name="SaveBtn" Content="Guardar" Margin="10,0,0,0" Click="SaveConnection_Click" />
                                </StackPanel>

                                <TextBlock x:Name="ConnResult" TextWrapping="Wrap" Margin="0,14,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ TAB 2: IMPORTAR ============ -->
            <TabItem Header="2 · Importar">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="3*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- File selection -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FilePathBox" Grid.Column="0" IsReadOnly="True" VerticalAlignment="Center" Text="" />
                        <Button x:Name="BrowseBtn" Grid.Column="1" Content="📂  Examinar…" Style="{StaticResource Secondary}"
                                Padding="14,9" Margin="10,0,0,0" Click="Browse_Click" />
                        <Button x:Name="AnalyzeBtn" Grid.Column="2" Content="Analizar" Margin="10,0,0,0" Click="Analyze_Click" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,6">
                        <TextBlock Text="Resumen por tabla" Style="{StaticResource H2}" VerticalAlignment="Center" Margin="0" />
                        <Button x:Name="KeyBtn" Content="🔑  Definir clave de la hoja…" Style="{StaticResource Secondary}"
                                HorizontalAlignment="Right" Click="DefineKey_Click" />
                    </Grid>

                    <DataGrid x:Name="SummaryGrid" Grid.Row="2" IsReadOnly="False" SelectionChanged="SummaryGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Importar" Binding="{Binding Include, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                            <DataGridTextColumn Header="Hoja" Binding="{Binding Sheet}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Tabla destino" Binding="{Binding Table}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Cabecera fila" Binding="{Binding HeaderRow}" Width="90" IsReadOnly="True" />
                            <DataGridTextColumn Header="Insertar" Binding="{Binding Insert}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="Actualizar" Binding="{Binding Update}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="Errores" Binding="{Binding Errors}" Width="70" IsReadOnly="True" />
                            <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="170" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TabControl Grid.Row="3" Margin="0,14,0,0">
                        <TabItem Header="Problemas detectados">
                            <DataGrid x:Name="IssuesGrid">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ubicación" Binding="{Binding Location}" Width="260" />
                                    <DataGridTextColumn Header="Gravedad" Binding="{Binding Severity}" Width="90" />
                                    <DataGridTextColumn Header="Motivo" Binding="{Binding Message}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Vista previa">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10,0,8">
                                    <TextBlock Text="Hoja:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Muted}" />
                                    <ComboBox x:Name="PreviewSheetCombo" Width="220" SelectionChanged="PreviewSheetCombo_SelectionChanged" />
                                    <TextBlock x:Name="PreviewNote" VerticalAlignment="Center" Margin="12,0,0,0" Style="{StaticResource Muted}" />
                                </StackPanel>
                                <DataGrid x:Name="PreviewGrid" Grid.Row="1" AutoGenerateColumns="True" />
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <Grid Grid.Row="4" Margin="0,16,0,0">
                        <TextBlock x:Name="ImportStatus" VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="ConfirmBtn" Content="✓  Confirmar e importar" HorizontalAlignment="Right"
                                IsEnabled="False" Click="Confirm_Click" Style="{StaticResource Success}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB 3: EXPORTAR ============ -->
            <TabItem Header="3 · Exportar">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Exportar tablas a Excel" Style="{StaticResource H1}" VerticalAlignment="Center" />
                        <Button x:Name="RefreshTablesBtn" Content="🔄  Cargar tablas" Style="{StaticResource Secondary}"
                                Margin="16,0,0,0" Click="RefreshTables_Click" />
                        <Button Content="Todos" Style="{StaticResource Secondary}" Margin="8,0,0,0" Click="SelectAllTables_Click" />
                        <Button Content="Ninguno" Style="{StaticResource Secondary}" Margin="8,0,0,0" Click="SelectNoneTables_Click" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Marca las tablas/vistas a exportar. Se genera un Excel con una hoja por tabla (cabecera = columnas), en el mismo formato que la importación." />

                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Filtrar:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource Muted}" />
                        <TextBox Grid.Column="1" x:Name="TableFilterBox" VerticalAlignment="Center" Margin="0" TextChanged="TableFilter_TextChanged" />
                        <TextBlock Grid.Column="2" Text="Máx. filas/tabla:" VerticalAlignment="Center" Margin="16,0,8,0" Style="{StaticResource Muted}" />
                        <TextBox Grid.Column="3" x:Name="MaxRowsBox" Width="100" VerticalAlignment="Center" Margin="0"
                                 ToolTip="Opcional. Vacío = todas las filas." />
                    </Grid>

                    <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10">
                        <ListBox x:Name="TablesList" BorderThickness="0" Background="Transparent" SelectionMode="Extended"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="6">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding Checked, Mode=TwoWay}" Margin="4,3" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Grid Grid.Row="4" Margin="0,14,0,0">
                        <TextBlock x:Name="ExportStatus" VerticalAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="ExportBtn" Content="⤓  Exportar a Excel…" HorizontalAlignment="Right"
                                Click="Export_Click" Style="{StaticResource Success}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB 4: HISTORIAL ============ -->
            <TabItem Header="4 · Historial">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Historial de importaciones" Style="{StaticResource H1}" VerticalAlignment="Center" />
                        <Button Content="🔄  Refrescar" Style="{StaticResource Secondary}" Margin="16,0,0,0" Click="RefreshHistory_Click" />
                    </StackPanel>
                    <DataGrid x:Name="HistoryGrid" Grid.Row="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha/hora" Binding="{Binding When}" Width="150" />
                            <DataGridTextColumn Header="Archivo" Binding="{Binding FileName}" Width="*" />
                            <DataGridTextColumn Header="Insertadas" Binding="{Binding Inserted}" Width="90" />
                            <DataGridTextColumn Header="Actualizadas" Binding="{Binding Updated}" Width="100" />
                            <DataGridTextColumn Header="Omitidas" Binding="{Binding Skipped}" Width="90" />
                            <DataGridTextColumn Header="Resultado" Binding="{Binding Result}" Width="120" />
                            <DataGridTextColumn Header="Detalle" Binding="{Binding Message}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
